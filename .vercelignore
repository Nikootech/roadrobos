# Don't upload local build outputs or cache
build/
.dart_tool/
.git/

# Don't upload native mobile/desktop folders (not needed for Web builds)
android/
ios/
windows/
macos/
linux/

# Don't upload local flutter SDK if cloned locally
flutter/

# ── Large binary artifacts that must never be uploaded ──────────────────────
# These Android/iOS release binaries are too large for Vercel's 100MB limit
# and are irrelevant to the Flutter Web build.
*.aab
*.apk
*.ipa

# Large asset files not used in web build
David Heckhoff*

# Test and integration directories (not needed at deploy time)
test/
integration_test/

# Python helper scripts (not used by Vercel build)
fix_unawaited.py
fix_unawaited2.py
