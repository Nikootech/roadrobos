# ─────────────────────────────────────────────────────────────────────────────
# dart_defines/dev.env  —  LOCAL DEVELOPMENT ONLY
#
# This file is gitignored. Never commit it.
# Copy this from dart_defines/dev.env.template and fill in your values.
#
# Usage:
#   flutter run --dart-define-from-file=dart_defines/dev.env
#   flutter test --dart-define-from-file=dart_defines/dev.env
#
# Keys must match exactly what String.fromEnvironment() reads in AppConfig.
# ─────────────────────────────────────────────────────────────────────────────

ENV=dev

# Supabase — get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Leave blank for client builds — only used server-side
SUPABASE_SERVICE_KEY=

# Google OAuth — Client ID (PKCE, no secret needed for mobile)
# Get from: Google Cloud Console → Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Razorpay — use test key (rzp_test_*) for dev/staging
# Get from: Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_YOUR_TEST_KEY_HERE

# Maps (optional — leave empty if not using maps features)
MAPS_API_KEY=
