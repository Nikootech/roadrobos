# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ═══ SECURITY — Never commit these ═══
# Service account keys, credentials, secrets
*-service-account-key.json
*-credentials.json
*service-account*.json
google-services.json
GoogleService-Info.plist

# Environment files — use dart_defines/ instead
.env
.env.*
*.env

# dart-define files — all variants are sensitive
.dart_defines
dart_defines/dev.env
dart_defines/staging.env
dart_defines/prod.env
dart_defines/prod.json
dart_defines/staging.json
# Keep: dart_defines/*.json.example or *.json.template (safe placeholders, no real values)

# Android signing — never commit keystores or passwords
*.jks
*.keystore
key.properties

# Firebase generated config (regenerate with flutterfire configure)
lib/firebase_options.dart

# Analysis artifacts (stale)
analysis_results.txt

# Dart-define secrets file (root-level, generated by CI)
.dart_defines

# Demo credentials (never commit)
DEMO_CREDENTIALS.md

# Diagnostic / build log text files
*.txt

# Web build
build/web/

# Scratch test files — historically contained hardcoded credentials
# Use test/ or integration_test/ directories for actual tests
test_patch*.dart

# Local security tooling — not for version control
verify_security.ps1
paths_to_purge.txt
.vercel

# Large build artifacts — exceed GitHub's 100 MB limit
*.aab
*.apk
app-release.aab
RoadRobos_Production.apk

# Ignore Android build artifacts
android/app/build/
android/app/.cxx/

