rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Only authenticated users can access their own files
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || userId.startsWith('demo_'));
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
